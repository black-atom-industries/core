{
    "nodeModulesDir": "auto",
    "unstable": ["sloppy-imports"],
    "tasks": {
        "dev": "deno run -A npm:vite",
        "build": "deno run -A npm:vite build",
        "check": "deno check src/main.tsx",
        "lint": "deno lint .",
        "format": "deno fmt .",
        "test": "deno test --allow-all",
        "checks": "deno task check && deno task lint && deno task test && deno task format"
    },
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "lib": ["ES2024", "DOM", "DOM.Iterable"]
    },
    "imports": {
        "react": "npm:react@^19.0.0",
        "react-dom": "npm:react-dom@^19.0.0",
        "react/jsx-runtime": "npm:react@^19.0.0/jsx-runtime",
        "@types/react": "npm:@types/react@^19.0.0",
        "@tanstack/react-query": "npm:@tanstack/react-query@^5.64.0",
        "@tanstack/react-router": "npm:@tanstack/react-router@^1.114.0",
        "@tanstack/router-plugin": "npm:@tanstack/router-plugin@^1.114.0",
        "@tanstack/react-form": "npm:@tanstack/react-form@^1",
        "@tanstack/react-store": "npm:@tanstack/react-store@^0",
        "@tanstack/react-hotkeys": "npm:@tanstack/react-hotkeys@^0",
        "@tanstack/zod-adapter": "npm:@tanstack/zod-adapter@^1.114.0",
        "@base-ui/react": "npm:@base-ui/react@^1.3.0",
        "culori": "npm:culori@4",
        "zod": "npm:zod@^3.24.0",
        "vite": "npm:vite@^6.1.0",
        "@vitejs/plugin-react-swc": "npm:@vitejs/plugin-react-swc@^3.8.0",
        "@core/": "../src/",
        "@std/assert": "jsr:@std/assert@^1.0.0"
    },
    "lint": {
        "rules": {
            "exclude": ["no-slow-types", "no-sloppy-imports"]
        },
        "exclude": [".vite/", "dist/", "src/routeTree.gen.ts"]
    },
    "fmt": {
        "exclude": ["src/routeTree.gen.ts"],
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false,
        "proseWrap": "preserve"
    }
}
