{
    "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    "name": "@black-atom/core",
    "version": "0.3.2",
    "exports": {
        ".": "./src/mod.ts",
        "./cli": "./src/cli/index.ts"
    },
    "publish": {
        "exclude": [
            "src/tasks/",
            "src/lib/generate-schema.ts",
            "src/lib/discover-adapters.ts"
        ]
    },
    "tasks": {
        "test": "deno test --allow-all",
        "lock": "deno cache --lock=deno.lock --reload .",
        "check": "deno check .",
        "checks": "deno task check && deno task format && deno task lint && deno task test && cd monitor && deno task checks",
        "format": "deno fmt .",
        "lint": "deno lint .",
        "schema": "deno run --allow-read --allow-write src/lib/generate-schema.ts && deno fmt .",
        "cli:compile": "deno compile --allow-read --allow-write --allow-env -o black-atom-core src/cli/index.ts",
        "cli:install": "cp black-atom-core /usr/local/bin/",
        "theme:commit": "deno run -A src/tasks/index.ts theme:commit",
        "adapters:gen": "deno run -A src/tasks/index.ts adapters:gen",
        "dev": "deno run -A src/tasks/dev.ts",
        "adapters:status": "deno run -A src/tasks/index.ts adapters:status",
        "adapters:commit": "deno run -A src/tasks/index.ts adapters:commit",
        "adapters:push": "deno run -A src/tasks/index.ts adapters:push",
        "adapters:reset": "deno run -A src/tasks/index.ts adapters:reset",
        "adapters:each": "deno run -A src/tasks/adapters/each.ts",
        "publish": "deno publish --allow-slow-types",
        "test:terminal-colors": "bash scripts/test-terminal-colors.sh",
        "test:terminal-colors:dev": "deno run -A scripts/test-terminal-colors-dev.ts",
        "monitor:api": "deno run -A src/monitor-server.ts",
        "monitor:app": "cd monitor && deno task dev",
        "install-hooks": "cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo 'Hooks installed.'"
    },
    "exclude": [
        "monitor/"
    ],
    "lint": {
        "rules": {
            "exclude": [
                "no-slow-types"
            ]
        },
        "exclude": [
            "deno.lock",
            "deno.json",
            "import_map.json",
            "CHANGELOG.md",
            "monitor/"
        ]
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false,
        "proseWrap": "preserve",
        "exclude": [
            "CHANGELOG.md",
            "monitor/src/routeTree.gen.ts"
        ]
    },
    "imports": {
        "@std/assert": "jsr:@std/assert@^1.0.0",
        "@std/fmt/colors": "jsr:@std/fmt@1.0.5/colors",
        "@std/path": "jsr:@std/path@^1.0.8",
        "@std/fs": "jsr:@std/fs@^1.0.0",
        "zod": "npm:zod@^3.24.2",
        "@eta": "jsr:@eta-dev/eta@3.5.0",
        "culori": "npm:culori@4"
    }
}
